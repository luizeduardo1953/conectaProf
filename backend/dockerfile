# ============================================================
# Dockerfile do Backend — NestJS
# ============================================================
# Stage 1: Dependências (cache separado)
# ============================================================
FROM node:22-alpine AS deps

WORKDIR /app

# Copia apenas os manifestos para aproveitar o cache de layers
COPY package*.json ./
RUN npm ci --only=production && \
    cp -r node_modules /tmp/prod_modules && \
    npm ci


# ============================================================
# Stage 2: Build da aplicação
# ============================================================
FROM node:22-alpine AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Gera o Prisma Client e compila o TypeScript
RUN npx prisma generate && npm run build


# ============================================================
# Stage 3: Imagem de produção (mínima)
# ============================================================
FROM node:22-alpine AS production

WORKDIR /app

ENV NODE_ENV=production

# Apenas os módulos de produção
COPY --from=deps /tmp/prod_modules ./node_modules
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma
COPY --from=builder /app/node_modules/@prisma ./node_modules/@prisma
COPY prisma ./prisma
COPY package*.json ./

EXPOSE 8000

CMD ["node", "dist/main.js"]